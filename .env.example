# =============================================================================
# Perfil WINDOWS — API en PowerShell/CMD (recomendado si Postgres está en Windows)
# =============================================================================
DATABASE_URL=postgresql://postgres:Parqueadero123@127.0.0.1:5433/ffcore?sslmode=disable

# =============================================================================
# Perfil WSL — API en Ubuntu/WSL (requiere firewall o networkingMode=mirrored)
# IP gateway: ip route show default  →  ej. 172.18.16.1
# =============================================================================
# DATABASE_URL=postgresql://postgres:Parqueadero123@172.18.16.1:5433/ffcore?sslmode=disable

JWT_SECRET=cambiar-en-produccion-min-32-chars-seguro
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173
PORT=3000
NODE_ENV=development
