# =============================================================================
# FFCore API — SOLO DESARROLLO LOCAL
# =============================================================================
# Nunca pongas aquí la URL de Neon/producción.
# En Render, DATABASE_URL y DIRECT_URL se configuran en el dashboard (Neon).
#
# Docker está en Ubuntu (WSL). Lo ideal: correr API + Docker DENTRO de Ubuntu.
# =============================================================================

# --- Perfil local (RECOMENDADO) ---
# Arranque completo (API + Postgres en Docker):
#   make fire
#   make seed
# Con make fire la API usa la BD del contenedor sola (no necesita este .env).
# Este .env sirve si corres la API en el host contra Postgres Docker.
DATABASE_URL=postgresql://ffcore:ffcore@127.0.0.1:5432/ffcore?sslmode=disable
DIRECT_URL=postgresql://ffcore:ffcore@127.0.0.1:5432/ffcore?sslmode=disable

# --- Si la API corre en Windows y Docker solo en Ubuntu ---
# 1) En Ubuntu: npm run db:up
# 2) Obtén la IP de WSL:  wsl hostname -I
# 3) Descomenta y sustituye LA_IP (ej. 172.18.16.1):
# DATABASE_URL=postgresql://ffcore:ffcore@LA_IP:5432/ffcore?sslmode=disable
# DIRECT_URL=postgresql://ffcore:ffcore@LA_IP:5432/ffcore?sslmode=disable

JWT_SECRET=local-dev-jwt-secret
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
PORT=3000
NODE_ENV=development
