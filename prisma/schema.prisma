generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  cliente
  admin
  domiciliario
  superadmin
}

enum UserStatus {
  Activo
  Pendiente
  Suspendido
  Rechazado
}

enum RestaurantStatus {
  Activo
  Pendiente
  Suspendido
  Rechazado
}

enum OrderStatus {
  Recibido
  EnPreparacion
  Listo
  EnCamino
  Entregado
  Cancelado
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded
}

enum PaymentMethod {
  Cash
  Online
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password_hash String
  role          Role
  phone         String?
  vehicle       String?
  document_id   String?
  avatar        String?
  /** Comuna de Cúcuta (clientes). */
  comuna        String?
  status        UserStatus @default(Pendiente)
  /** Preferencia de turno del domiciliario (buscar pedidos). */
  is_available  Boolean    @default(false)
  restaurant_id String?
  restaurant    Restaurant? @relation(fields: [restaurant_id], references: [id])
  orders        Order[]    @relation("CourierOrders")
  dispatches    Dispatch[] @relation("DispatchCourier")
  delivery_reviews DeliveryReview[] @relation("CourierDeliveryReviews")
  courier_applications CourierApplication[] @relation("CourierApplications")
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@map("users")
}

model Restaurant {
  id               String           @id @default(uuid())
  name             String
  tagline          String?
  city             String
  address          String
  rating           Float            @default(0)
  delivery_minutes Int              @default(30)
  monthly_goal     Int?
  daily_goal       Int?
  accent           String           @default("#4f46e5")
  initials         String
  logo             String?
  cover_image      String?
  status           RestaurantStatus @default(Pendiente)

  nequi_number     String?
  nequi_owner      String?
  breb_key         String?
  breb_owner       String?
  breb_qr_url      String?

  users            User[]
  products         Product[]
  orders           Order[]
  categories       Category[]
  promotions       Promotion[]
  reviews          Review[]
  delivery_reviews DeliveryReview[]
  dispatches       Dispatch[]
  courier_applications CourierApplication[]
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  @@map("restaurants")
}

model Category {
  id            String     @id @default(uuid())
  name          String
  position      Int        @default(0)
  image         String?
  restaurant_id String
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  products      Product[]

  @@unique([restaurant_id, name])
  @@map("categories")
}

model Product {
  id            String     @id @default(uuid())
  name          String
  description   String
  price         Int
  image         String
  available     Boolean    @default(true)
  category      Category   @relation(fields: [category_id], references: [id])
  category_id   String
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id])
  restaurant_id String
  ingredients   ProductIngredient[]
  modifier_groups ModifierGroup[]
  order_items   OrderItem[]
  promotions    PromotionProduct[]
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@map("products")
}

model Order {
  id                 String      @id @default(uuid())
  code               String      @unique
  customer_name      String
  address            String
  phone              String
  notes              String?
  zone               String?
  status             OrderStatus @default(Recibido)
  status_entered_at  DateTime    @default(now())
  payment_method      PaymentMethod @default(Cash)
  payment_status      PaymentStatus @default(Pending)
  payment_observation String?
  total              Int
  delivery_fee       Int         @default(5000)
  restaurant         Restaurant  @relation(fields: [restaurant_id], references: [id])
  restaurant_id      String
  delivery_person    User?       @relation("CourierOrders", fields: [delivery_person_id], references: [id])
  delivery_person_id String?
  items              OrderItem[]
  dispatch           Dispatch?
  delivery_review    DeliveryReview?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  @@map("orders")
}

model UserReport {
  id            String   @id @default(uuid())
  reported_user String
  reported_by   String
  reason        String
  created_at    DateTime @default(now())

  @@map("user_reports")
}

model OrderItem {
  id         String  @id @default(uuid())
  quantity   Int
  unit_price Int
  order      Order   @relation(fields: [order_id], references: [id])
  order_id   String
  product    Product @relation(fields: [product_id], references: [id])
  product_id String
  customizations Json?

  @@map("order_items")
}

model Ingredient {
  id         String     @id @default(uuid())
  name       String
  available  Boolean    @default(true)
  products   ProductIngredient[]
  
  @@map("ingredients")
}

model ProductIngredient {
  id            String     @id @default(uuid())
  product_id    String
  ingredient_id String
  product       Product    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)

  @@unique([product_id, ingredient_id])
  @@map("product_ingredients")
}

model ModifierGroup {
  id             String           @id @default(uuid())
  name           String
  product_id     String
  product        Product          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  min_selections Int              @default(0)
  max_selections Int              @default(1)
  options        ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id          String        @id @default(uuid())
  name        String
  price_extra Int           @default(0)
  available   Boolean       @default(true)
  group_id    String
  group       ModifierGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@map("modifier_options")
}

model Promotion {
  id               String     @id @default(uuid())
  name             String
  discount_percent Int
  start_date       DateTime
  end_date         DateTime
  active           Boolean    @default(true)
  restaurant_id    String
  restaurant       Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  products         PromotionProduct[]
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  @@map("promotions")
}

model PromotionProduct {
  id           String    @id @default(uuid())
  promotion_id String
  product_id   String
  promotion    Promotion @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([promotion_id, product_id])
  @@map("promotion_products")
}

model Review {
  id            String     @id @default(uuid())
  rating        Float
  comment       String?
  customer_name String
  restaurant_id String
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  created_at    DateTime   @default(now())

  @@map("reviews")
}

/** Reseña post-entrega: restaurante + domiciliario en un solo registro por pedido. */
model DeliveryReview {
  id                  String     @id @default(uuid())
  order_id            String     @unique
  order               Order      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  restaurant_id       String
  restaurant          Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  courier_id          String?
  courier             User?      @relation("CourierDeliveryReviews", fields: [courier_id], references: [id], onDelete: SetNull)
  customer_name       String
  restaurant_rating   Float
  restaurant_comment  String?
  courier_rating      Float?
  courier_comment     String?
  created_at          DateTime   @default(now())

  @@index([restaurant_id])
  @@index([courier_id])
  @@map("delivery_reviews")
}

model Dispatch {
  id         String   @id @default(uuid())
  order_id   String   @unique
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  courier_id String
  courier    User     @relation("DispatchCourier", fields: [courier_id], references: [id])
  restaurant_id String
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  dispatched_at DateTime @default(now())

  @@map("dispatches")
}

model CourierApplication {
  id            String            @id @default(uuid())
  courier_id    String
  courier       User              @relation("CourierApplications", fields: [courier_id], references: [id])
  restaurant_id String
  restaurant    Restaurant        @relation(fields: [restaurant_id], references: [id])
  status        ApplicationStatus @default(PENDING)
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  @@unique([courier_id, restaurant_id])
  @@map("courier_applications")
}

