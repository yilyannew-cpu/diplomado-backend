{
  "info": {
    "name": "FFCore API v1",
    "description": "FFCore REST API - Fase 1: Auth y Registros.\n\nVariables de coleccion:\n- baseUrl: http://localhost:3000/api/v1\n- token: JWT (se guarda automaticamente al hacer login)\n\nUsuarios demo (password: demo):\n- super@ffcore.co (superadmin)\n- admin@ffcore.co (admin)\n- cliente@ffcore.co (cliente)\n- domi@ffcore.co (domiciliario)\n- vale@ffcore.co (cliente suspendido)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "clientToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Verificacion de disponibilidad del servicio.",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Autenticacion y registro publico.",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response has token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.user).to.be.an('object');",
                  "  pm.collectionVariables.set('token', body.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ffcore.co\",\n  \"password\": \"demo\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login con credenciales validas. Guarda el JWT en {{token}}."
          },
          "response": []
        },
        {
          "name": "POST /auth/login (superadmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.token) pm.collectionVariables.set('token', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"super@ffcore.co\",\n  \"password\": \"demo\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": []
        },
        {
          "name": "POST /auth/login (suspended account)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));",
                  "pm.test('ACCOUNT_SUSPENDED', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('ACCOUNT_SUSPENDED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vale@ffcore.co\",\n  \"password\": \"demo\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Caso negativo: cuenta suspendida."
          },
          "response": []
        },
        {
          "name": "POST /auth/register/client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Auto-login returns token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.expect(body.user.role).to.eql('cliente');",
                  "  pm.expect(body.user.status).to.eql('Activo');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Cliente\",\n  \"email\": \"nuevo.cliente@ffcore.co\",\n  \"password\": \"demo1234\",\n  \"password_confirmation\": \"demo1234\",\n  \"phone\": \"+57 300 111 2233\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/client"
          },
          "response": []
        },
        {
          "name": "POST /auth/register/restaurant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('No token on pending registration', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.undefined;",
                  "  pm.expect(body.data.status).to.eql('Pendiente');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner_name\": \"Maria Restrepo\",\n  \"email\": \"maria.rest@ffcore.co\",\n  \"password\": \"demo1234\",\n  \"password_confirmation\": \"demo1234\",\n  \"phone\": \"+57 300 000 0000\",\n  \"restaurant_name\": \"Mi Restaurante\",\n  \"tagline\": \"Comida casera\",\n  \"city\": \"Medellin - El Poblado\",\n  \"address\": \"Calle 10 #43-28\",\n  \"delivery_minutes\": 30\n}"
            },
            "url": "{{baseUrl}}/auth/register/restaurant"
          },
          "response": []
        },
        {
          "name": "POST /auth/register/courier",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('No token on pending registration', () => {",
                  "  pm.expect(pm.response.json().token).to.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pedro Dominguez\",\n  \"email\": \"pedro.domi@ffcore.co\",\n  \"password\": \"demo1234\",\n  \"password_confirmation\": \"demo1234\",\n  \"phone\": \"+57 320 555 9999\",\n  \"document_id\": \"1098765432\",\n  \"vehicle_type\": \"Moto\",\n  \"vehicle_plate\": \"ABC-123\",\n  \"vehicle_description\": \"Moto AKT\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/courier"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth (Bearer)",
      "description": "Endpoints que requieren JWT en Authorization header.",
      "item": [
        {
          "name": "GET /auth/me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          },
          "response": []
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "description": "Gestion de usuarios. Requiere rol superadmin.",
      "item": [
        {
          "name": "GET /users/pending",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/pending",
            "description": "Cola de registros pendientes de aprobacion."
          },
          "response": []
        },
        {
          "name": "GET /users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?role=admin&status=Activo",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "role", "value": "admin", "description": "cliente | admin | domiciliario | superadmin" },
                { "key": "status", "value": "Activo", "description": "Activo | Pendiente | Suspendido | Rechazado" },
                { "key": "q", "value": "", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /users/:id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Detalle de usuario por UUID."
          },
          "response": []
        },
        {
          "name": "POST /users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Courier Creado\",\n  \"email\": \"courier.creado@ffcore.co\",\n  \"password\": \"demo1234\",\n  \"role\": \"domiciliario\",\n  \"phone\": \"+57 320 555 8888\",\n  \"vehicle\": \"Moto Yamaha - XYZ-99\"\n}"
            },
            "url": "{{baseUrl}}/users",
            "description": "Crear usuario (solo superadmin)."
          },
          "response": []
        },
        {
          "name": "POST /users (superadmin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Super Admin 2\",\n  \"email\": \"super2@ffcore.co\",\n  \"password\": \"demo1234\",\n  \"role\": \"superadmin\",\n  \"phone\": \"+57 300 555 0002\"\n}"
            },
            "url": "{{baseUrl}}/users"
          },
          "response": []
        },
        {
          "name": "PATCH /users/:id/approve",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "approve"]
            },
            "description": "Aprueba solicitud pendiente. Si es admin, activa tambien el restaurante."
          },
          "response": []
        },
        {
          "name": "PATCH /users/:id/reject",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Documentacion incompleta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "reject"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Security",
      "description": "Casos de autorizacion y acceso denegado.",
      "item": [
        {
          "name": "GET /users/pending (forbidden - cliente)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/auth/login',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: {",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({ email: 'cliente@ffcore.co', password: 'demo' })",
                  "  }",
                  "}, (err, res) => {",
                  "  if (!err && res.json().token) {",
                  "    pm.collectionVariables.set('clientToken', res.json().token);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{clientToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/pending"
          },
          "response": []
        },
        {
          "name": "POST /users (unauthorized)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hack\",\n  \"email\": \"hack@ffcore.co\",\n  \"password\": \"demo1234\",\n  \"role\": \"superadmin\"\n}"
            },
            "url": "{{baseUrl}}/users",
            "description": "Sin JWT no se puede crear superadmin."
          },
          "response": []
        }
      ]
    }
  ]
}
