    },
    {
      "name": "Superadmin",
      "item": [
        {
          "name": "GET Pending registrations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/pending"
          }
        },
        {
          "name": "GET Users (filtros)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users?role=admin&status=Activo",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "role", "value": "admin" },
                { "key": "status", "value": "Activo" }
              ]
            }
          }
        },
        {
          "name": "PATCH Approve user",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/:id/approve",
            "variable": [{ "key": "id", "value": "USER_UUID_AQUI" }]
          }
        },
        {
          "name": "PATCH Reject user",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"DocumentaciÃ³n incompleta\"\n}"
            },
            "url": "{{baseUrl}}/users/:id/reject",
            "variable": [{ "key": "id", "value": "USER_UUID_AQUI" }]
          }
        },
