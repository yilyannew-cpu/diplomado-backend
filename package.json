{
  "name": "ffcore-api",
  "version": "1.0.0",
  "description": "FFCore API - Fase 1: Autenticación y Registros",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "build:render": "prisma generate && node scripts/migrate-deploy.cjs && tsc",
    "start": "node dist/server.js",
    "start:render": "node dist/server.js",
    "setup": "node scripts/setup.cjs",
    "setup:clean": "node scripts/setup.cjs --clean",
    "setup:docker": "node scripts/local.cjs",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "catalog:seed": "node scripts/ensure-catalogs.cjs",
    "local": "node scripts/local.cjs",
    "local:dev": "node scripts/local.cjs --dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset-data": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "ffcore",
    "api",
    "express",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "prisma": "^6.9.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.15.32",
    "@types/socket.io": "^3.0.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": "20.x"
  }
}
